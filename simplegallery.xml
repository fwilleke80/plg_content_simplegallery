<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="content" method="upgrade">
	<name>PLG_CONTENT_SIMPLEGALLERY</name>
	<author>Frank Willeke</author>
	<creationDate>2026-03-21</creationDate>
	<copyright>(c) 2026 by Frank Willeke</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE</license>
	<authorEmail></authorEmail>
	<authorUrl></authorUrl>
	<version>1.1.8</version>
	<description>PLG_CONTENT_SIMPLEGALLERY_XML_DESCRIPTION</description>
	<namespace path="src">Joomla\Plugin\Content\Simplegallery</namespace>

	<files>
		<folder plugin="simplegallery">services</folder>
		<folder>src</folder>
		<folder>language</folder>
		<folder>media</folder>
		<folder>tmpl</folder>
		<filename>index.html</filename>
	</files>

	<media destination="plg_content_simplegallery" folder="media">
		<folder>css</folder>
		<folder>js</folder>
	</media>

	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.plg_content_simplegallery.ini</language>
		<language tag="en-GB">en-GB/en-GB.plg_content_simplegallery.sys.ini</language>
		<language tag="de-DE">de-DE/de-DE.plg_content_simplegallery.ini</language>
		<language tag="de-DE">de-DE/de-DE.plg_content_simplegallery.sys.ini</language>
	</languages>

	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="columns"
					type="number"
					label="PLG_CONTENT_SIMPLEGALLERY_COLUMNS_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_COLUMNS_DESC"
					default="4"
					min="1"
					max="12"
				/>

				<field
					name="thumb_width"
					type="number"
					label="PLG_CONTENT_SIMPLEGALLERY_THUMB_WIDTH_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_THUMB_WIDTH_DESC"
					default="240"
					min="32"
					max="2000"
				/>

				<field
					name="thumb_height"
					type="number"
					label="PLG_CONTENT_SIMPLEGALLERY_THUMB_HEIGHT_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_THUMB_HEIGHT_DESC"
					default="180"
					min="32"
					max="2000"
				/>

				<field
					name="show_captions"
					type="radio"
					label="PLG_CONTENT_SIMPLEGALLERY_SHOW_CAPTIONS_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_SHOW_CAPTIONS_DESC"
					default="0"
					class="btn-group btn-group-yesno"
				>
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>

				<field
					name="layout"
					type="list"
					label="PLG_CONTENT_SIMPLEGALLERY_LAYOUT_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_LAYOUT_DESC"
					default="grid"
				>
					<option value="grid">PLG_CONTENT_SIMPLEGALLERY_LAYOUT_GRID</option>
					<option value="slider">PLG_CONTENT_SIMPLEGALLERY_LAYOUT_SLIDER</option>
				</field>

				<field
					name="sort"
					type="list"
					label="PLG_CONTENT_SIMPLEGALLERY_SORT_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_SORT_DESC"
					default="filename"
				>
					<option value="filename">PLG_CONTENT_SIMPLEGALLERY_SORT_FILENAME</option>
					<option value="date">PLG_CONTENT_SIMPLEGALLERY_SORT_DATE</option>
					<option value="random">PLG_CONTENT_SIMPLEGALLERY_SORT_RANDOM</option>
				</field>

				<field
					name="sort_order"
					type="list"
					label="PLG_CONTENT_SIMPLEGALLERY_SORT_ORDER_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_SORT_ORDER_DESC"
					default="ascending"
				>
					<option value="ascending">PLG_CONTENT_SIMPLEGALLERY_SORT_ORDER_ASCENDING</option>
					<option value="descending">PLG_CONTENT_SIMPLEGALLERY_SORT_ORDER_DESCENDING</option>
				</field>

				<field
					name="cache_folder"
					type="text"
					label="PLG_CONTENT_SIMPLEGALLERY_CACHE_FOLDER_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_CACHE_FOLDER_DESC"
					default="images/.simplegallery-cache"
					size="40"
				/>
			</fieldset>
		</fields>
	</config>
</extension>