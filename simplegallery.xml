<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="content" method="upgrade">
	<name>PLG_CONTENT_SIMPLEGALLERY</name>
	<author>Frank Willeke</author>
	<creationDate>2026-03-21</creationDate>
	<copyright>(C) 2026 by Frank Willeke</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail></authorEmail>
	<authorUrl></authorUrl>
	<version>1.0.12</version>
	<description>PLG_CONTENT_SIMPLEGALLERY_XML_DESCRIPTION</description>
	<namespace path="src">Joomla\Plugin\Content\Simplegallery</namespace>

	<files>
		<folder plugin="simplegallery">services</folder>
		<folder>src</folder>
		<folder>language</folder>
		<folder>media</folder>
		<filename>index.html</filename>
	</files>

	<media destination="plg_content_simplegallery" folder="media">
		<folder>css</folder>
	</media>

	<languages folder="language">
		<language tag="en-GB">en-GB/en-GB.plg_content_simplegallery.ini</language>
		<language tag="en-GB">en-GB/en-GB.plg_content_simplegallery.sys.ini</language>
	</languages>

	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="columns"
					type="number"
					label="PLG_CONTENT_SIMPLEGALLERY_COLUMNS_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_COLUMNS_DESC"
					default="4"
					min="1"
					max="12"
				/>

				<field
					name="thumb_width"
					type="number"
					label="PLG_CONTENT_SIMPLEGALLERY_THUMB_WIDTH_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_THUMB_WIDTH_DESC"
					default="240"
					min="32"
					max="2000"
				/>

				<field
					name="thumb_height"
					type="number"
					label="PLG_CONTENT_SIMPLEGALLERY_THUMB_HEIGHT_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_THUMB_HEIGHT_DESC"
					default="180"
					min="32"
					max="2000"
				/>

				<field
					name="cache_folder"
					type="text"
					label="PLG_CONTENT_SIMPLEGALLERY_CACHE_FOLDER_LABEL"
					description="PLG_CONTENT_SIMPLEGALLERY_CACHE_FOLDER_DESC"
					default="images/.simplegallery-cache"
					size="40"
				/>
			</fieldset>
		</fields>
	</config>
</extension>